# ============================================================
# Watch Tower · Fase 2 env vars
# ============================================================
# Copie pra .env.local (dev) e adicione no Vercel Production env.

# ---- Database (Neon Postgres free tier) ----
# Crie conta gratis em https://neon.tech, gere connection string com SSL
# Cole tanto o pooled (DATABASE_URL) quanto o direct (DIRECT_URL pro Prisma migrate)
DATABASE_URL="postgresql://USER:PASS@HOST.neon.tech/DB?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASS@HOST.neon.tech/DB?sslmode=require"

# ---- Auth (NextAuth v5) ----
# Gere com: openssl rand -hex 32
AUTH_SECRET=""
# Em producao isso fica https://watchtower.wisehubnow.online
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ---- Resend (Magic Link emails) ----
# Reaproveite a API key do WiseRank (mesmo dominio verificado wisehubnow.online)
RESEND_API_KEY=""
EMAIL_FROM="Watch Tower <noreply@wisehubnow.online>"

# ---- Cron Worker (opcional) ----
# Setar quando Cloudflare Worker estiver deployado
WT_GEO_PROXY_URL=""
WT_GEO_PROXY_SECRET=""
# Ponte SSO Watch Tower -> Friday/Wise (mesmo valor no friday-cloud; nunca NEXT_PUBLIC_)
WT_BRAIN_SSO_SECRET=
WT_BRAIN_URL=https://wise.wisehubnow.online
